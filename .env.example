# ─── App ─────────────────────────────────────────────────────────────────────
# development | staging | production
APP_ENV=development

# REQUIRED in production. Generate with: openssl rand -hex 32
# The app refuses to start when APP_ENV=production and this is left as the default.
SECRET_KEY=changeme

HOST=127.0.0.1
PORT=8000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the React frontend.
# Development default is the Vite dev server.
# Production: set to your actual frontend URL (e.g. https://app.example.com)
ALLOWED_ORIGINS=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase (production) — Transaction Pooler URL from Supabase dashboard (port 6543):
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# SQLite (local dev / testing only — requires aiosqlite):
# DATABASE_URL=sqlite+aiosqlite:///./app.db

# ─── AI ──────────────────────────────────────────────────────────────────────
# Obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
